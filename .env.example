# Host port published by Docker Compose.
HOST_PORT=8787

# Base URL of the Docker Model Runner API. Inside a container, `localhost` is
# the container itself, so the runner must be addressed explicitly.
#
#   Docker Desktop host:  http://model-runner.docker.internal  (default)
#   Runner as container:  http://docker-model-runner:12434
#                         (join the runner's network in compose.yaml)
#   Docker Engine host:   http://host.docker.internal:12434
#                         (also add `host.docker.internal:host-gateway` to
#                          extra_hosts, and enable host-side TCP on the runner)
#   Remote runner:        https://dmr.example.com
MODEL_RUNNER_URL=http://model-runner.docker.internal
